# Telegram
TELEGRAM_BOT_TOKEN=seu_token_aqui
# CSV de user IDs autorizados
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJ...

# Groq (transcrição)
GROQ_API_KEY=gsk_...

# Anthropic (caso Claude Code use API key em vez de OAuth)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (embeddings pro Chat Manager — text-embedding-3-small)
# Obtenha em https://platform.openai.com/api-keys e adicione créditos
# em Billing (mínimo $5 dura anos no uso típico). Custo estimado: ~$0.01/mês.
# Também é o FALLBACK do plugin Monet (geração de imagem via gpt-image-1).
OPENAI_API_KEY=sk-proj-...

# Google Gemini — backend principal do plugin Monet (gemini-2.5-flash-image).
# Obtenha em https://aistudio.google.com/apikey. ~$0.039 por imagem gerada.
GEMINI_API_KEY=AIza...

# Chat Manager (Fases 1-7 implementadas; ligar quando confiar). Quando
# true, detector de tema cria/reabre/troca conversations automaticamente
# a cada msg, e o prompt do Hal carrega cronologia comprimida das
# sessions arquivadas da conversation. Quando false, sistema antigo
# (sessions ortogonais) segue intacto.
CHAT_MANAGER_ENABLED=false

# Núcleo curado global (Highlander Frente 1.2): auto-injeta USER.md + MEMORY.md
# (identidade do operador + fatos duráveis do agente) no topo do prompt, com
# teto e sinal de consolidação. DEFAULT-ON (puro-cômputo, no-op se faltar
# arquivo). Pra desligar: CURATED_CORE_ENABLED=false + restart.
CURATED_CORE_ENABLED=true

# Sinais de grounding baratos (Highlander Frente 1.1): injeta no prompt o que
# muda com o tempo e o agente senão narraria de memória — hoje, há quanto tempo
# foi a última troca neste tópico (anti-confabulação temporal + lembrete de
# retomada). DEFAULT-ON (no-op se não há histórico). Desligar: =false + restart.
GROUNDING_SIGNALS_ENABLED=true

# Memória durável via Hindsight (Highlander Frente 2.3): recall na entrada do
# turno + retain no fim (destila fato da msg do operador). DEFAULT-ON; exige o
# serviço Hindsight de pé (ver infra/hindsight/). Se o serviço estiver fora, é
# best-effort: falha rápido (connection refused) e o turno segue. Desligar
# (ex.: instalação sem Hindsight): HINDSIGHT_ENABLED=false + restart.
HINDSIGHT_ENABLED=true
HINDSIGHT_BASE_URL=http://127.0.0.1:8888
HINDSIGHT_TIMEOUT_SECONDS=10
HINDSIGHT_RECALL_LIMIT=5

# Paths (preenchidos pelo instalador)
KOBE_HOME=/home/seu_usuario/projetos/kobe
KOBE_CLAUDE_CWD=/home/seu_usuario/projetos/kobe

# Config
LOG_LEVEL=INFO
CLAUDE_TIMEOUT_SECONDS=300
RECENT_MESSAGES_LIMIT=20
# Quantas mensagens uma sessão ativa pode acumular antes da compactação
# automática (v0.12). Quando atingido, o bot gera summary via Claude,
# arquiva a sessão (status='compacted') e abre uma nova com o summary
# como contexto inicial. Threshold ALTO = prompts maiores, mais tokens.
# Threshold BAIXO = mais transições, mais chamadas de summary.
COMPACT_THRESHOLD_MESSAGES=40

# ─── Despacho de turno pesado em background (cascata de filtros) ───
# Quando true, a ENTRADA do turno classifica se o pedido vai gerar trabalho
# pesado (editar código, varrer repo, análise longa, processar arquivos/URLs)
# e, se for, despacha o `claude -p` em background FORA do lock do tópico —
# o Hal (atendente) fica livre pro próximo pedido na hora. O resultado do
# pesado chega de forma assíncrona (mensagem depois). Quando false, o sistema
# clássico roda intacto (turno foreground, lock segurado o turno inteiro).
# Rollback trivial: flag off + restart. Ver bot/turn_classifier.py e
# docs/runbooks/despacho-turno-pesado.md.
HEAVY_DISPATCH_ENABLED=false
# Retaguarda (teto de tempo): turno que entrou foreground mas estoura estes
# segundos segurando o lock se promove sozinho pra background e libera a
# linha (o claude em voo NÃO recomeça — continua e reporta no fim). É o
# tempo máximo que se aceita ficar preso no pior caso (erro de previsão).
# Baixo (6-8s) = libera rápido mas chuta turnos legítimos longos pro async;
# alto (15-20s) = quase nunca chuta à toa mas erro real custa mais espera.
HEAVY_DISPATCH_PROMOTE_AFTER_SECONDS=12
# Cortes do placar da cascata. score >= HIGH → background na entrada (previsão);
# score <= LOW → foreground; faixa do meio acorda o GPT-4o-mini pra desempatar
# (zona cinza, ~1s, fora da cota do plano Max). Subir HIGH = menos previsões
# de background; subir LOW = mais chamadas ao mini.
HEAVY_DISPATCH_SCORE_HIGH=6
HEAVY_DISPATCH_SCORE_LOW=2
# Teto de tempo do `claude -p` no caminho de despacho pesado (background, tanto
# na previsão quanto na promoção). O turno de bg é o PESADO por definição —
# 300s (default do foreground) corta no meio e a resposta chega truncada
# ("estourei o tempo limite no meio"). Dimensionado pro trabalho pesado real,
# não infinito. Só vale com HEAVY_DISPATCH_ENABLED=true.
HEAVY_DISPATCH_TIMEOUT_SECONDS=1200
# Watchdog de ACK no background: se a run de bg não emitir um `kobe-notify`
# (ack na voz do Hal, que nomeia a ação) dentro destes segundos e ainda
# estiver rodando, o código manda o aviso enlatado como piso garantido — o
# operador nunca fica no escuro mesmo que o Hal não acke a tempo.
HEAVY_DISPATCH_ACK_FALLBACK_SECONDS=20

# ─── Plugins (opcionais — só se o plugin estiver instalado) ───
# Plugin atrus (kobe-plugin-atrus): transcrição de URLs via Firecrawl + Groq Whisper.
# - FIRECRAWL_API_KEY: obrigatória se o atrus estiver instalado. https://www.firecrawl.dev
# - HF_TOKEN: obrigatória SE você usar /transcrever-speakers ou /transcrever-leitura-speakers
#   (diarização via pyannote local). Veja docs/runbooks/pyannote-setup.md no repo do plugin.
# FIRECRAWL_API_KEY=fc-...
# HF_TOKEN=hf_...

# AssemblyAI (diarização atrus + fallback Whisper) — pegar em https://www.assemblyai.com/app/account
ASSEMBLYAI_API_KEY=
