# Telegram
TELEGRAM_BOT_TOKEN=seu_token_aqui
# CSV de user IDs autorizados
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJ...

# Groq (transcrição)
GROQ_API_KEY=gsk_...

# Anthropic (caso Claude Code use API key em vez de OAuth)
# ANTHROPIC_API_KEY=sk-ant-...

# Paths (preenchidos pelo instalador)
KOBE_HOME=/home/seu_usuario/projetos/kobe
KOBE_CLAUDE_CWD=/home/seu_usuario/projetos/kobe

# Config
LOG_LEVEL=INFO
CLAUDE_TIMEOUT_SECONDS=300
RECENT_MESSAGES_LIMIT=20
# Quantas mensagens uma sessão ativa pode acumular antes da compactação
# automática (v0.12). Quando atingido, o bot gera summary via Claude,
# arquiva a sessão (status='compacted') e abre uma nova com o summary
# como contexto inicial. Threshold ALTO = prompts maiores, mais tokens.
# Threshold BAIXO = mais transições, mais chamadas de summary.
COMPACT_THRESHOLD_MESSAGES=40

# ─── Plugins (opcionais — só se o plugin estiver instalado) ───
# Plugin atrus (kobe-plugin-atrus): transcrição de URLs via Firecrawl + Groq Whisper.
# - FIRECRAWL_API_KEY: obrigatória se o atrus estiver instalado. https://www.firecrawl.dev
# - HF_TOKEN: obrigatória SE você usar /transcrever-speakers ou /transcrever-leitura-speakers
#   (diarização via pyannote local). Veja docs/runbooks/pyannote-setup.md no repo do plugin.
# FIRECRAWL_API_KEY=fc-...
# HF_TOKEN=hf_...

# AssemblyAI (diarização atrus + fallback Whisper) — pegar em https://www.assemblyai.com/app/account
ASSEMBLYAI_API_KEY=
