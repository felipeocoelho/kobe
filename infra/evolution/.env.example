# Evolution API v2.3.7 — config
# Copie pra .env e preencha. Não commitar (.env está no .gitignore).

# ============================================================================
# Server
# ============================================================================
SERVER_NAME=evolution
SERVER_TYPE=http
SERVER_PORT=8080
SERVER_URL=http://127.0.0.1:8080

# Telemetria/Sentry off (privacidade do operador)
TELEMETRY_ENABLED=false
SENTRY_DSN=

# Logs (LOG_LEVEL controla os tipos exibidos)
LOG_LEVEL=ERROR,WARN,INFO,LOG,WEBHOOKS
LOG_COLOR=true
LOG_BAILEYS=warn

# Instância expira da memória após 5min sem conexão (false = nunca expira)
DEL_INSTANCE=false

# ============================================================================
# Banco (Postgres dedicado dentro do compose)
# ============================================================================
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:CHANGE_ME@evolution-postgres:5432/evolution_db?schema=evolution_api
DATABASE_CONNECTION_CLIENT_NAME=evolution_exchange

# Persistência: salvamos messages/contacts/chats no Postgres da Evolution
# (isolado do Supabase do Kobe — Apolo replica só o que precisa via webhook).
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true
DATABASE_SAVE_DATA_LABELS=false
DATABASE_SAVE_DATA_HISTORIC=false
DATABASE_SAVE_IS_ON_WHATSAPP=true
DATABASE_SAVE_IS_ON_WHATSAPP_DAYS=7
DATABASE_DELETE_MESSAGE=false

# ============================================================================
# Cache (Redis dedicado dentro do compose)
# ============================================================================
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://evolution-redis:6379/6
CACHE_REDIS_TTL=604800
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_REDIS_SAVE_INSTANCES=false
CACHE_LOCAL_ENABLED=false

# ============================================================================
# Filas (desligadas — Apolo usa webhook HTTP simples)
# ============================================================================
RABBITMQ_ENABLED=false
SQS_ENABLED=false
KAFKA_ENABLED=false
WEBSOCKET_ENABLED=false
PUSHER_ENABLED=false

# ============================================================================
# WhatsApp Business Cloud API (desligado — usamos Baileys)
# ============================================================================
WA_BUSINESS_TOKEN_WEBHOOK=evolution
WA_BUSINESS_URL=https://graph.facebook.com
WA_BUSINESS_VERSION=v20.0
WA_BUSINESS_LANGUAGE=pt_BR

# ============================================================================
# Webhook global — DESLIGADO (vamos setar por instância via API após criação,
# pra passar header customizado X-Apolo-Secret que o webhook_server espera)
# ============================================================================
WEBHOOK_GLOBAL_ENABLED=false
WEBHOOK_GLOBAL_URL=
WEBHOOK_GLOBAL_WEBHOOK_BY_EVENTS=false

# Eventos por instância (default Evolution v2.3.7). Apolo precisa de:
# MESSAGES_UPSERT, CONNECTION_UPDATE, QRCODE_UPDATED. Resto fica off pra
# reduzir tráfego pro webhook_server.
WEBHOOK_EVENTS_APPLICATION_STARTUP=false
WEBHOOK_EVENTS_QRCODE_UPDATED=true
WEBHOOK_EVENTS_MESSAGES_SET=false
WEBHOOK_EVENTS_MESSAGES_UPSERT=true
WEBHOOK_EVENTS_MESSAGES_EDITED=false
WEBHOOK_EVENTS_MESSAGES_UPDATE=false
WEBHOOK_EVENTS_MESSAGES_DELETE=false
WEBHOOK_EVENTS_SEND_MESSAGE=false
WEBHOOK_EVENTS_SEND_MESSAGE_UPDATE=false
WEBHOOK_EVENTS_CONTACTS_SET=false
WEBHOOK_EVENTS_CONTACTS_UPSERT=false
WEBHOOK_EVENTS_CONTACTS_UPDATE=false
WEBHOOK_EVENTS_PRESENCE_UPDATE=false
WEBHOOK_EVENTS_CHATS_SET=false
WEBHOOK_EVENTS_CHATS_UPSERT=false
WEBHOOK_EVENTS_CHATS_UPDATE=false
WEBHOOK_EVENTS_CHATS_DELETE=false
WEBHOOK_EVENTS_GROUPS_UPSERT=false
WEBHOOK_EVENTS_GROUPS_UPDATE=false
WEBHOOK_EVENTS_GROUP_PARTICIPANTS_UPDATE=false
WEBHOOK_EVENTS_CONNECTION_UPDATE=true
WEBHOOK_EVENTS_REMOVE_INSTANCE=false
WEBHOOK_EVENTS_LOGOUT_INSTANCE=false
WEBHOOK_EVENTS_LABELS_EDIT=false
WEBHOOK_EVENTS_LABELS_ASSOCIATION=false
WEBHOOK_EVENTS_CALL=false
WEBHOOK_EVENTS_TYPEBOT_START=false
WEBHOOK_EVENTS_TYPEBOT_CHANGE_STATUS=false
WEBHOOK_EVENTS_ERRORS=false
WEBHOOK_EVENTS_ERRORS_WEBHOOK=

WEBHOOK_REQUEST_TIMEOUT_MS=60000
WEBHOOK_RETRY_MAX_ATTEMPTS=10
WEBHOOK_RETRY_INITIAL_DELAY_SECONDS=5
WEBHOOK_RETRY_USE_EXPONENTIAL_BACKOFF=true
WEBHOOK_RETRY_MAX_DELAY_SECONDS=300
WEBHOOK_RETRY_JITTER_FACTOR=0.2
WEBHOOK_RETRY_NON_RETRYABLE_STATUS_CODES=400,401,403,404,422

# ============================================================================
# Identidade do "aparelho" mostrada na lista de Aparelhos Conectados do
# WhatsApp Business do operador.
# ============================================================================
CONFIG_SESSION_PHONE_CLIENT=Kobe Apolo
CONFIG_SESSION_PHONE_NAME=Chrome

# Limite de retry de QR antes da Evolution desistir
QRCODE_LIMIT=30
QRCODE_COLOR='#175197'

# ============================================================================
# Integrações externas (todas off — Apolo não usa)
# ============================================================================
TYPEBOT_ENABLED=false
CHATWOOT_ENABLED=false
OPENAI_ENABLED=false
DIFY_ENABLED=false
N8N_ENABLED=false
EVOAI_ENABLED=false
S3_ENABLED=false

# ============================================================================
# Auth global (apikey enviado no header `apikey: ...` em todas as requests)
# Pra produção: rode `openssl rand -hex 16` e cole abaixo.
# ============================================================================
AUTHENTICATION_API_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_16
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=true
LANGUAGE=pt-BR

# Proxy global desligado — passamos proxy por instância no payload de
# /instance/create (mais flexível pra rotacionar proxy depois sem rebuild)
# PROXY_HOST=
# PROXY_PORT=
# PROXY_PROTOCOL=http
# PROXY_USERNAME=
# PROXY_PASSWORD=

# ============================================================================
# Senha do Postgres dedicado (substituída no DATABASE_CONNECTION_URI também)
# Pra produção: rode `openssl rand -hex 16` e cole abaixo + no URI acima.
# ============================================================================
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_16
