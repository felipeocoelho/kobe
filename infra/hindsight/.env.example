# Hindsight — config do serviço de memória durável (Highlander Frente 2)
# Copie pra .env e preencha. NUNCA commite o .env real.
#   cp .env.example .env

# --- Postgres dedicado (pgvector) ---
# Senha do Postgres do Hindsight. Gere com: openssl rand -hex 16
HINDSIGHT_DB_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_16
# Opcionais (defaults no compose): usuário, banco, versão da imagem pgvector.
HINDSIGHT_DB_USER=hindsight_user
HINDSIGHT_DB_NAME=hindsight_db
HINDSIGHT_DB_VERSION=18

# --- Versão do serviço Hindsight (pinada; nunca latest) ---
# Atenção: a tag da IMAGEM Docker é sem o 'v' (0.8.3), diferente do release
# do GitHub (v0.8.3). Tag errada = "manifest not found" no compose up.
HINDSIGHT_VERSION=0.8.3

# --- Provedor LLM/embedding: OpenAI (reusa a chave do Kobe) ---
# Cole aqui a MESMA OPENAI_API_KEY que o bot usa (ver $KOBE_HOME/.env).
OPENAI_API_KEY=sk-proj-...
HINDSIGHT_LLM_PROVIDER=openai
# Override de modelo só se necessário (default do Hindsight = mini-tier OpenAI):
# HINDSIGHT_API_LLM_MODEL=gpt-4o-mini
