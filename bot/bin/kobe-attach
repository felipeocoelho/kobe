#!/usr/bin/env python3
"""kobe-attach — envia arquivo como documento pro chat ativo do operador.

Uso:
    kobe-attach <path-do-arquivo> [caption opcional]
    kobe-attach --topic "Dev Kobe" <path-do-arquivo> [caption opcional]

Plugins do Kobe usam este helper pra entregar artefatos (txt, html,
pdf, etc.) sem precisar passar pelo agente principal. Útil pra
transcrições, relatórios, exportações — tudo que é melhor consumir
como arquivo do que como mensagem inline.

Dois modos de endereçamento (iguais ao kobe-notify):

1. **Por ambiente** (default): KOBE_TELEGRAM_BOT_TOKEN / KOBE_CHAT_ID /
   KOBE_THREAD_ID (opcional), injetadas pelo bot ao invocar `claude -p`.
2. **Por nome do tópico** (`--topic "<nome>"`): resolve o destino pela tabela
   `topics` do Supabase (match por current_name/slug). Pra salas detached que
   nascem sem KOBE_CHAT_ID. Token cai pra TELEGRAM_BOT_TOKEN do .env.

Implementação: chama `curl` em subprocess pra evitar reimplementar
multipart/form-data em Python puro. `curl` é dependência do Kobe
(instalada pelo install.sh), então está sempre disponível.
"""

from __future__ import annotations

import os
import subprocess
import sys
from pathlib import Path

# Dir dos helpers no sys.path pra importar `_kobe_topic` (resolução --topic).
_HELPER_DIR = Path(__file__).resolve().parent
if str(_HELPER_DIR) not in sys.path:
    sys.path.insert(0, str(_HELPER_DIR))

from _kobe_topic import parse_topic_arg, read_dotenv, resolve_topic  # noqa: E402


def main() -> int:
    try:
        topic, rest = parse_topic_arg(sys.argv[1:])
    except ValueError as exc:
        print(f"kobe-attach: {exc}", file=sys.stderr)
        return 2
    if not rest:
        print('uso: kobe-attach [--topic "<nome>"] <path> [caption]', file=sys.stderr)
        return 2
    path = Path(rest[0])
    caption = " ".join(rest[1:]) if len(rest) > 1 else ""

    if not path.is_file():
        print(f"kobe-attach: arquivo não existe: {path}", file=sys.stderr)
        return 1

    token = os.environ.get("KOBE_TELEGRAM_BOT_TOKEN", "").strip()
    if not token and topic is not None:
        token = (read_dotenv({"TELEGRAM_BOT_TOKEN"}).get("TELEGRAM_BOT_TOKEN") or "").strip()

    if topic is not None:
        # Caminho novo: resolve o destino pelo nome do tópico (Supabase).
        try:
            chat_id_int, thread_int = resolve_topic(topic)
        except LookupError as exc:
            print(f"kobe-attach: {exc}", file=sys.stderr)
            return 1
        chat_id = str(chat_id_int)
        thread_id = str(thread_int) if thread_int else ""
    else:
        # Caminho clássico (retrocompat dura): destino vem das envs do bot.
        chat_id = os.environ.get("KOBE_CHAT_ID", "").strip()
        thread_id = os.environ.get("KOBE_THREAD_ID", "").strip()

    if not token or not chat_id:
        print(
            "kobe-attach: token/destino ausentes (KOBE_TELEGRAM_BOT_TOKEN + "
            'KOBE_CHAT_ID no ambiente, ou --topic "<nome>" + .env)',
            file=sys.stderr,
        )
        return 1

    args = [
        "curl",
        "--silent",
        "--fail",
        "--show-error",
        "--max-time", "120",
        "-F", f"chat_id={chat_id}",
        "-F", f"document=@{path}",
    ]
    if thread_id:
        args.extend(["-F", f"message_thread_id={thread_id}"])
    if caption:
        args.extend(["-F", f"caption={caption}"])
    args.append(f"https://api.telegram.org/bot{token}/sendDocument")

    try:
        result = subprocess.run(args, capture_output=True, timeout=150)
    except FileNotFoundError:
        print("kobe-attach: `curl` não encontrado no sistema.", file=sys.stderr)
        return 1
    except subprocess.TimeoutExpired:
        print("kobe-attach: timeout enviando documento.", file=sys.stderr)
        return 1

    if result.returncode != 0:
        stderr = result.stderr.decode("utf-8", errors="replace")[:400]
        print(f"kobe-attach falhou: curl exit={result.returncode} {stderr}", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main())
