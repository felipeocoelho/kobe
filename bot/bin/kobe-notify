#!/usr/bin/env python3
"""kobe-notify — envia mensagem de texto pro chat ativo do operador.

Uso:
    kobe-notify "texto da mensagem"

Plugins do Kobe usam este helper pra emitir progresso enquanto rodam,
em vez de acumular tudo na resposta final do agente.

Variáveis de ambiente (injetadas pelo bot do Kobe ao invocar `claude -p`):
    KOBE_TELEGRAM_BOT_TOKEN   token do bot
    KOBE_CHAT_ID              chat onde a notificação aparece
    KOBE_THREAD_ID            (opcional) forum topic; vazio = "general"

Sai com código 0 em sucesso, !=0 em falha (mensagem vai pro stderr).
"""

from __future__ import annotations

import json
import os
import sys
import urllib.error
import urllib.request


def main() -> int:
    if len(sys.argv) < 2:
        print("uso: kobe-notify <texto>", file=sys.stderr)
        return 2
    text = " ".join(sys.argv[1:])

    token = os.environ.get("KOBE_TELEGRAM_BOT_TOKEN", "").strip()
    chat_id = os.environ.get("KOBE_CHAT_ID", "").strip()
    thread_id = os.environ.get("KOBE_THREAD_ID", "").strip()

    if not token or not chat_id:
        print(
            "kobe-notify: envs KOBE_TELEGRAM_BOT_TOKEN/KOBE_CHAT_ID ausentes "
            "(o helper só funciona quando chamado a partir de um agente do Kobe)",
            file=sys.stderr,
        )
        return 1

    payload: dict = {"chat_id": int(chat_id), "text": text}
    if thread_id:
        payload["message_thread_id"] = int(thread_id)

    req = urllib.request.Request(
        f"https://api.telegram.org/bot{token}/sendMessage",
        data=json.dumps(payload).encode("utf-8"),
        headers={"Content-Type": "application/json"},
    )
    try:
        urllib.request.urlopen(req, timeout=15).read()
    except urllib.error.HTTPError as exc:
        body = exc.read().decode("utf-8", errors="replace")[:300]
        print(f"kobe-notify falhou: HTTP {exc.code} {body}", file=sys.stderr)
        return 1
    except Exception as exc:  # noqa: BLE001 — rede/timeout
        print(f"kobe-notify falhou: {exc}", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main())
