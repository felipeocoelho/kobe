#!/usr/bin/env python3
"""kobe-notify — envia mensagem de texto pro chat do operador.

Uso:
    kobe-notify "texto da mensagem"
    kobe-notify --topic "Dev Kobe" "texto da mensagem"

Plugins do Kobe usam este helper pra emitir progresso enquanto rodam,
em vez de acumular tudo na resposta final do agente. Aceita markdown
padrão (`**bold**`, `*italic*`, `` `code` ``, `[link](url)` etc.) —
converte pra HTML supported pelo Telegram antes de enviar.

Dois modos de endereçamento:

1. **Por ambiente** (default — usado por agentes/plugins do Kobe): lê o
   destino das envs injetadas pelo bot ao invocar `claude -p`:
       KOBE_TELEGRAM_BOT_TOKEN   token do bot
       KOBE_CHAT_ID              chat onde a notificação aparece
       KOBE_THREAD_ID            (opcional) forum topic; vazio = "general"

2. **Por nome do tópico** (`--topic "<nome>"`): resolve o nome humano →
   `telegram_chat_id` + `telegram_thread_id` consultando a tabela `topics`
   do Supabase. Útil pra salas de código detached, que nascem sem as envs
   `KOBE_CHAT_ID`/`KOBE_THREAD_ID`. O match é por `current_name`
   case-insensitive OU pelo slug (`Dev Kobe`→`dev-kobe`). Credenciais do
   Supabase saem do `.env` do projeto (SUPABASE_URL/SUPABASE_KEY). O token
   ainda vem de KOBE_TELEGRAM_BOT_TOKEN (env) ou TELEGRAM_BOT_TOKEN (.env).

Sai com código 0 em sucesso, !=0 em falha (mensagem vai pro stderr).
"""

from __future__ import annotations

import json
import os
import sys
import urllib.error
import urllib.request
from pathlib import Path

# Raiz do projeto ($KOBE_HOME) e dir dos helpers no sys.path: o helper roda
# como subprocess de `claude -p` (cwd=$KOBE_HOME). Importa `bot.markdown` (da
# raiz) e `_kobe_topic` (do próprio dir bin/, resolução de tópico compartilhada).
_HELPER_DIR = Path(__file__).resolve().parent
_PROJECT_ROOT = _HELPER_DIR.parent.parent
for _p in (str(_PROJECT_ROOT), str(_HELPER_DIR)):
    if _p not in sys.path:
        sys.path.insert(0, _p)

from _kobe_topic import parse_topic_arg, resolve_topic  # noqa: E402

try:
    from bot.markdown import to_telegram_html
except ImportError:
    # Fallback se o módulo não estiver disponível (instalação atípica):
    # manda como texto plain.
    def to_telegram_html(text: str) -> str:  # type: ignore[misc]
        return text


def _read_token_from_env_file() -> str:
    """TELEGRAM_BOT_TOKEN do `.env` — fallback do modo --topic (sala detached)."""
    from _kobe_topic import read_dotenv

    return (read_dotenv({"TELEGRAM_BOT_TOKEN"}).get("TELEGRAM_BOT_TOKEN") or "").strip()


def _send(token: str, chat_id: int, thread_id: int | None, text: str) -> int:
    """Envia o texto (HTML, com fallback plain) pro Telegram. Retorna exit code."""
    html_text = to_telegram_html(text)
    payload: dict = {
        "chat_id": chat_id,
        "text": html_text,
        "parse_mode": "HTML",
    }
    if thread_id:
        payload["message_thread_id"] = int(thread_id)

    req = urllib.request.Request(
        f"https://api.telegram.org/bot{token}/sendMessage",
        data=json.dumps(payload).encode("utf-8"),
        headers={"Content-Type": "application/json"},
    )
    try:
        urllib.request.urlopen(req, timeout=15).read()
    except urllib.error.HTTPError as exc:
        body = exc.read().decode("utf-8", errors="replace")[:300]
        # Se HTML deu ruim (tag órfã etc), tenta de novo como texto plain.
        if exc.code == 400 and "parse_mode" not in body.lower() and "parse entities" in body.lower():
            payload.pop("parse_mode", None)
            payload["text"] = text
            req = urllib.request.Request(
                f"https://api.telegram.org/bot{token}/sendMessage",
                data=json.dumps(payload).encode("utf-8"),
                headers={"Content-Type": "application/json"},
            )
            try:
                urllib.request.urlopen(req, timeout=15).read()
                return 0
            except Exception as exc2:  # noqa: BLE001
                print(f"kobe-notify falhou (fallback plain): {exc2}", file=sys.stderr)
                return 1
        print(f"kobe-notify falhou: HTTP {exc.code} {body}", file=sys.stderr)
        return 1
    except Exception as exc:  # noqa: BLE001 — rede/timeout
        print(f"kobe-notify falhou: {exc}", file=sys.stderr)
        return 1
    return 0


def main() -> int:
    try:
        topic, rest = parse_topic_arg(sys.argv[1:])
    except ValueError as exc:
        print(f"kobe-notify: {exc}", file=sys.stderr)
        return 2
    text = " ".join(rest)
    if not text:
        print('uso: kobe-notify [--topic "<nome>"] <texto>', file=sys.stderr)
        return 2

    # Token: env injetada pelo bot ou, no modo --topic (sala detached), do .env.
    token = os.environ.get("KOBE_TELEGRAM_BOT_TOKEN", "").strip()
    if not token and topic is not None:
        token = _read_token_from_env_file()
    if not token:
        print(
            "kobe-notify: token ausente (KOBE_TELEGRAM_BOT_TOKEN no ambiente "
            "ou TELEGRAM_BOT_TOKEN no .env)",
            file=sys.stderr,
        )
        return 1

    if topic is not None:
        # Caminho novo: resolve o destino pelo nome do tópico (Supabase).
        try:
            chat_id, thread_id = resolve_topic(topic)
        except LookupError as exc:
            print(f"kobe-notify: {exc}", file=sys.stderr)
            return 1
    else:
        # Caminho clássico (retrocompat dura): destino vem das envs do bot.
        chat_id_env = os.environ.get("KOBE_CHAT_ID", "").strip()
        thread_env = os.environ.get("KOBE_THREAD_ID", "").strip()
        if not chat_id_env:
            print(
                "kobe-notify: envs KOBE_TELEGRAM_BOT_TOKEN/KOBE_CHAT_ID ausentes "
                "(o helper só funciona quando chamado a partir de um agente do "
                'Kobe, ou passe --topic "<nome>")',
                file=sys.stderr,
            )
            return 1
        chat_id = int(chat_id_env)
        thread_id = int(thread_env) if thread_env else None

    return _send(token, chat_id, thread_id, text)


if __name__ == "__main__":
    sys.exit(main())
