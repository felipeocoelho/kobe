# Variáveis de ambiente (NUNCA commitar)
.env
.env.*
!.env.example
*.env.backup

# Backups de dados — dumps locais do banco, NUNCA versionados.
backups/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Workspace dinâmico (criado em runtime pelo Kobe)
projetos/*
!projetos/.gitkeep

# Plugins — cada plugin é um repo separado (público em plugins/public/<nome>/,
# privado em plugins/private/<nome>/). Kobe-base não trackeia o conteúdo.
plugins/

# user-data/ — dados do operador, NUNCA versionados no repo público.
# BLANKET: ignora TUDO em user-data/, exceto os templates .example que o repo
# público precisa pra onboarding. Qualquer subdir novo de runtime (alertas,
# whatsapp, chat-manager, missoes, imports, lembretes, etc.) já nasce protegido
# — não precisa adicionar regra a cada feature. Esse foi o furo que existia:
# allowlist por subdir deixava subdir novo escapar pro git.
user-data/*
!user-data/identity/
!user-data/persona/
user-data/identity/*
user-data/persona/*
!user-data/identity/*.example
!user-data/persona/*.example

# Logs
*.log
.kobe-install.log

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Build / dist
dist/
build/

# Rascunhos, planos, dumps temporários (notas locais, scripts ad-hoc,
# saídas de análise). Funciona em qualquer lugar da árvore. Vide CLAUDE.md.
.local/
**/.local/

# Scripts locais de conveniência do mantenedor (não vai pra repo)
claude.sh
