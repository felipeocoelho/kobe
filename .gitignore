# Variáveis de ambiente (NUNCA commitar)
.env
.env.local
*.env.backup

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Workspace dinâmico (criado em runtime pelo Kobe)
projetos/*
!projetos/.gitkeep

# user-data/ — dados do operador, NUNCA versionados no repo público.
# Só os templates .example são trackados; as cópias preenchidas ficam
# fora do Git pra não vazar identidade/conhecimento/preferências.
user-data/identity/*
!user-data/identity/*.example
user-data/persona/*
!user-data/persona/*.example
user-data/knowledge/*
!user-data/knowledge/.gitkeep
user-data/topics/
user-data/transcription-hints.md

# Logs
*.log
.kobe-install.log

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Build / dist
dist/
build/
